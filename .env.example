# ============================================================
# Glow Beauty Goals — Production Environment Variables
# Copy this to .env and fill in your real values
# ============================================================

# Database
DB_PASSWORD=GlowBeauty2026!

# JWT Secrets (generate strong random strings for production!)
JWT_SECRET=change-me-to-a-strong-random-string-64-chars
ADMIN_JWT_SECRET=change-me-to-another-strong-random-string-64-chars

# Frontend URL (your domain or IP)
FRONTEND_URL=https://glowandbeautygoals.urbanbasketbd.com

# API URL that the browser will use (must be publicly reachable)
# If using Nginx reverse proxy on same domain:
NEXT_PUBLIC_API_URL=https://glowandbeautygoals.urbanbasketbd.com

# API URL that the Next.js server/container uses internally
INTERNAL_API_URL=http://backend:8080

# Meta Conversions API Graph version
META_GRAPH_API_VERSION=v24.0


# Cloudinary
CLOUDINARY_URL=
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=
NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET=
